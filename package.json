{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "tsx packages/database/src/seed.ts"
  },
  "scripts": {
    "build": "turbo run build",
    "db:migrate:deploy": "turbo run db:migrate:deploy",
    "db:push": "infisical run -- turbo run db:push",
    "db:seed": "infisical run -- turbo run db:seed",
    "studio": "infisical run -- turbo run studio",
    "dev": "infisical run -- turbo run dev --concurrency 11",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "generate": "turbo run generate",
    "lint": "turbo run lint",
    "postinstall": "yarn generate"
  },
  "devDependencies": {
    "dotenv-cli": "latest",
    "prettier": "^2.5.1",
    "tsx": "^3.7.1",
    "turbo": "latest"
  },
  "packageManager": "yarn@1.22.17"
}
